	| SpellId('Target_HypnoticPattern_6')
	| SpellId('Target_Invisibility_Greater')
	| SpellId('Target_Invisibility_Greater_5')
	| SpellId('Target_Invisibility_Greater_6')
	| SpellId('Target_PhantasmalKiller')
	| SpellId('Target_PhantasmalKiller_5')
	| SpellId('Target_PhantasmalKiller_6')
	| SpellId('Target_Seeming')
	| SpellId('Target_Seeming_6')
end

function ArcaneWard()
	return SpellId('Shout_ArcaneWard')
	 | SpellId('Shout_ArcaneWard_1')
	 | SpellId('Shout_ArcaneWard_2')
	 | SpellId('Shout_ArcaneWard_3')
	 | SpellId('Shout_ArcaneWard_4')
	 | SpellId('Shout_ArcaneWard_5')
	 | SpellId('Shout_ArcaneWard_6')
end